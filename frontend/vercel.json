{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "provider.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "staging-provider.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "broker.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "staging-broker.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "employer.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "staging-employer.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "signal.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "staging-signal.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "health.civicscale.ai" }],
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "staging-health.civicscale.ai" }],
      "destination": "/index.html"
    },
    { "source": "/parity-health/:path*", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/broker",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://broker.civicscale.ai/",
      "permanent": true
    },
    {
      "source": "/broker/",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://broker.civicscale.ai/",
      "permanent": true
    },
    {
      "source": "/broker/:path*",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://broker.civicscale.ai/:path*",
      "permanent": true
    },
    {
      "source": "/broker/:path*",
      "has": [{ "type": "host", "value": "www.civicscale.ai" }],
      "destination": "https://broker.civicscale.ai/:path*",
      "permanent": true
    },
    {
      "source": "/billing/employer",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://employer.civicscale.ai/",
      "permanent": true
    },
    {
      "source": "/billing/employer/",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://employer.civicscale.ai/",
      "permanent": true
    },
    {
      "source": "/billing/employer/:path*",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://employer.civicscale.ai/:path*",
      "permanent": true
    },
    {
      "source": "/billing/employer/:path*",
      "has": [{ "type": "host", "value": "www.civicscale.ai" }],
      "destination": "https://employer.civicscale.ai/:path*",
      "permanent": true
    },
    {
      "source": "/signal",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://signal.civicscale.ai/",
      "permanent": true
    },
    {
      "source": "/signal/",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://signal.civicscale.ai/",
      "permanent": true
    },
    {
      "source": "/signal/:path*",
      "has": [{ "type": "host", "value": "civicscale.ai" }],
      "destination": "https://signal.civicscale.ai/:path*",
      "permanent": true
    },
    {
      "source": "/signal/:path*",
      "has": [{ "type": "host", "value": "www.civicscale.ai" }],
      "destination": "https://signal.civicscale.ai/:path*",
      "permanent": true
    }
  ]
}
