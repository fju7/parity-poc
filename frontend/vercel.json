{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "provider.civicscale.ai" }],
      "destination": "/index.html"
    },
    { "source": "/parity-health/:path*", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

