# Backend environment variables
# Copy to .env and fill in values

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Supabase (for future Phase 1 endpoints)
SUPABASE_URL=https://kfxxpscdwoemtzylhhhb.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Stripe (Parity Signal subscriptions)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PRICE_STANDARD_MONTHLY=price_xxx
STRIPE_PRICE_STANDARD_ANNUAL=price_xxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
STRIPE_PRICE_PREMIUM_ANNUAL=price_xxx
FRONTEND_URL=http://localhost:5173

# Resend (email delivery for Signal notifications)
RESEND_API_KEY=re_your_key_here

# Cron secret (shared secret for service endpoints)
CRON_SECRET=your_cron_secret_here
